{
  "title": "Benchmark score vs. real operational skill",
  "metric": "TSS (True Skill Statistic; higher is better, 0 = no skill)",
  "method": {
    "peak": "best TSS over all thresholds (Youden's J) \u2014 a threshold-free skill ceiling, fair across test sets but generous",
    "frozen": "TSS with the validation-tuned threshold committed in advance \u2014 the honest deployment score",
    "bootstrap": "1000 cluster-bootstrap resamples (whole active regions, because windows of one region are correlated), 95% percentile CIs, paired across models",
    "climatology_note": "a constant-probability (climatology) forecast has TSS = 0 by construction \u2014 the zero line IS the climatology baseline",
