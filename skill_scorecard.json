      "gap": 0.083
    },
    {
      "name": "Live-trained",
      "detail": "JSOC live data (2014)",
      "benchmark_tss": 0.914,
      "operational_tss": 0.799,
      "gap": 0.115
    }
  ],
  "findings": {
    "benchmarks_overstate": true,
    "overstatement_gap": 0.083,
    "live_training_closes_gap": false
  }
}