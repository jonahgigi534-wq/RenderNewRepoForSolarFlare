{
  "title": "Benchmark score vs. real operational skill",
  "metric": "peak TSS (True Skill Statistic; higher is better, 0 = no skill)",
  "test_sets": {
    "benchmark": "held-out SWAN-SF magnetograms (14690 windows, 236 flares)",
    "operational": "live JSOC 2015, an unseen year (12597 windows, 273 flares)"
  },
  "models": [
    {
      "name": "Benchmark-trained",
      "detail": "SWAN-SF 2010-2012",
